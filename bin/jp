#!/usr/bin/env bash
set -euo pipefail
MODELS=/etc/jp-ai/models.json
API=http://127.0.0.1:11434
hf(){ jq -r --arg k "$1" '.[$k].hf // empty' "$MODELS"; }
case "${1:-help}" in
 doctor) jp-doctor ;;
 benchmark) jp-benchmark ;;
 status) systemctl --no-pager status jp-llama-router; sudo docker ps ;;
 models) curl -fsS "$API/models?reload=1" | jq ;;
 pull) m="$(hf "${2:-}")"; [[ -n "$m" ]] || exit 1; curl -fsS -X POST "$API/models" -H 'Content-Type: application/json' -d "$(jq -nc --arg model "$m" '{model:$model}')" | jq ;;
 load) m="$(hf "${2:-}")"; [[ -n "$m" ]] || exit 1; curl -fsS -X POST "$API/models/load" -H 'Content-Type: application/json' -d "$(jq -nc --arg model "$m" '{model:$model}')" | jq ;;
 unload) m="$(hf "${2:-}")"; [[ -n "$m" ]] || exit 1; curl -fsS -X POST "$API/models/unload" -H 'Content-Type: application/json' -d "$(jq -nc --arg model "$m" '{model:$model}')" | jq ;;
 logs) sudo journalctl -u jp-llama-router -f ;;
 update) git -C "$HOME/JP-AI-Server" pull; sudo rm -f /var/lib/jp-ai/state/05-llama.done /var/lib/jp-ai/state/07-services.done; "$HOME/JP-AI-Server/install.sh" ;;
 backup) t="$(date +%Y%m%d-%H%M%S)"; sudo tar -czf "/mnt/AI/backups/jp-ai-$t.tar.gz" /etc/jp-ai /opt/jp-ai ;;
 install-codebase-memory) curl -fsSL https://raw.githubusercontent.com/DeusData/codebase-memory-mcp/main/install.sh | bash ;;
 *) echo "jp doctor|status|models|pull|load|unload|logs|benchmark|update|backup|install-codebase-memory" ;;
esac
