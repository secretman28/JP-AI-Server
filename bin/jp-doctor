#!/usr/bin/env bash
set -u
ok(){ echo "[OK]   $*"; }; bad(){ echo "[FAIL] $*"; }
mountpoint -q /mnt/AI && ok "NFS monté" || bad "NFS absent"
[[ -w /mnt/AI ]] && ok "NFS écrivable" || bad "NFS lecture seule"
command -v nvcc >/dev/null && ok "nvcc présent" || bad "nvcc absent"
count="$(nvidia-smi --query-gpu=index --format=csv,noheader 2>/dev/null | wc -l)"
[[ "$count" -eq 3 ]] && ok "3 V100 visibles" || bad "$count GPU visibles"
systemctl is-active --quiet jp-llama-router && ok "llama router actif" || bad "llama router arrêté"
curl -fsS http://127.0.0.1:11434/health >/dev/null && ok "API llama" || bad "API llama"
curl -fsS "http://127.0.0.1:8080/search?q=test&format=json" >/dev/null && ok "SearXNG" || bad "SearXNG"
curl -fsS http://127.0.0.1:3000 >/dev/null && ok "Open WebUI" || bad "Open WebUI"
